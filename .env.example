# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://estalatree:estalatree@localhost:5432/estalatree

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# ── Duitku (payment gateway) ─────────────────────────────────────────────────
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_CALLBACK_URL=https://yourdomain.com/billing/webhook/duitku/
DUITKU_SANDBOX=True

# ── Google OAuth (django-allauth) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── WhatsApp ─────────────────────────────────────────────────────────────────
WA_BACKEND=console
WA_TOKEN=

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@estalatree.com
